{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 启动控制台",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/console"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "problemMatcher": [],
            "detail": "启动 Vite 开发服务器 (localhost:5173)"
        },
        {
            "label": "🚀 启动core后台",
            "type": "shell",
            "command": "..\\.conda\\python.exe -m uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload",
            "options": {
                "cwd": "${workspaceFolder}/platform"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "problemMatcher": [],
            "detail": "启动 FastAPI 后端服务 (localhost:8000, 热重载)"
        },
        {
            "label": "🚀 启动业务App后台",
            "type": "shell",
            "command": ".\\.conda\\python.exe -m uvicorn app.src.main:app --host 0.0.0.0 --port 9000 --reload --reload-dir app/src/features",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false
            },
            "problemMatcher": [],
            "detail": "启动 Business App 后端服务 (localhost:9000, 热重载)"
        }
    ]
}